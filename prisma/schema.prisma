generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


model Restaurant {
  id               String     @id @default(dbgenerated("(gen_random_uuid())::text"))
  name             String
  address          String
  phone            String?
  gstNumber        String?
  taxRate          Float      @default(18)
  currency         String     @default("INR")
  timeZone         String     @default("Asia/Kolkata")
  serviceChargeRate Float     @default(0)
  enableDelivery   Boolean    @default(true)
  minOrderAmount   Float      @default(300)
  deliveryCharge   Float      @default(0)
  printShowLogo    Boolean    @default(true)
  printShowGST     Boolean    @default(true)
  printKOTAuto     Boolean    @default(false)
  kdsDisplayToken  String?    @unique
  createdAt        DateTime   @default(now())
  menuItems        MenuItem[]
  tables           Table[]
  users            User[]
  orders           Order[]
  bills            Bill[]
}


model Table {
  id           String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  number       Int
  capacity     Int
  status       TableStatus @default(AVAILABLE)
  restaurantId String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @default(now()) @updatedAt
  bills        Bill[]
  orders       Order[]
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id])

  @@unique([restaurantId, number])
  @@index([restaurantId])
  @@index([status])
  @@index([restaurantId, status]) // ⚡ PERFORMANCE: Fast dashboard query
}

model MenuItem {
  id                String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  name              String
  category          String
  price             Float
  priceHalf         Float?
  hasHalfFullOption Boolean     @default(false)
  imageUrl          String
  available         Boolean     @default(true)
  dietType          DietType    @default(VEG)
  stockQuantity     Int?
  restaurantId      String
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @default(now()) @updatedAt
  restaurant        Restaurant  @relation(fields: [restaurantId], references: [id])
  orderItems        OrderItem[]

  @@index([restaurantId])
  @@index([category])
  @@index([available])
  @@index([restaurantId, category])
}

model Order {
  id            String        @id @default(dbgenerated("(gen_random_uuid())::text"))
  tableId       String?
  status        OrderStatus   @default(PENDING)
  totalAmount   Float         @default(0)
  paymentStatus PaymentStatus @default(PENDING)
  orderType     OrderType     @default(DINE_IN)
  guests        Int?
  version       Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @default(now()) @updatedAt
  customerName  String?
  customerPhone String?
  restaurantId  String?
  bill          Bill?
  table         Table?        @relation(fields: [tableId], references: [id])
  restaurant    Restaurant?   @relation(fields: [restaurantId], references: [id])
  items         OrderItem[]

  @@index([tableId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([customerPhone])
  @@index([tableId, status]) // ⚡ PERFORMANCE: Fast bill generation query
  @@index([restaurantId]) // ⚡ PERFORMANCE: Multi-tenant fetching
  @@index([restaurantId, status]) // ⚡ PERFORMANCE: Multi-tenant fetching
}

model OrderItem {
  id                  String       @id @default(dbgenerated("(gen_random_uuid())::text"))
  orderId             String
  menuItemId          String
  quantity            Int
  price               Float
  portionType         PortionType?
  status              ItemStatus   @default(ACTIVE)
  kotPrinted          Boolean      @default(false)
  specialInstructions String?
  cancelReason        String?
  cancelledByUserId   String?
  createdAt           DateTime     @default(now())
  cancelledBy         User?        @relation(fields: [cancelledByUserId], references: [id])
  menuItem            MenuItem     @relation(fields: [menuItemId], references: [id])
  order               Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([menuItemId])
  @@index([status])
  @@index([orderId, status])
}

model Bill {
  id                String             @id @default(dbgenerated("(gen_random_uuid())::text"))
  orderId           String             @unique
  tableId           String?
  customerId        String?
  subtotal          Float
  tax               Float
  discount          Float              @default(0)
  total             Float
  gstApplied        Boolean            @default(true)
  serviceChargeApplied Boolean         @default(false)
  serviceChargeAmount  Float           @default(0)
  status            BillStatus         @default(PENDING)
  paymentMethod     String?
  cashAmount        Float              @default(0)
  onlineAmount      Float              @default(0)
  pointsEarned      Int                @default(0)
  pointsRedeemed    Int                @default(0)
  createdAt         DateTime           @default(now())
  paidAt            DateTime?
  restaurantId      String?
  customer          Customer?          @relation(fields: [customerId], references: [id])
  order             Order              @relation(fields: [orderId], references: [id])
  table             Table?             @relation(fields: [tableId], references: [id])
  restaurant        Restaurant?        @relation(fields: [restaurantId], references: [id])
  pointTransactions PointTransaction[]

  @@index([status])
  @@index([createdAt])
  @@index([customerId])
  @@index([status, createdAt])
  @@index([paidAt])
  @@index([tableId]) // ⚡ PERFORMANCE: Table bills lookup
  @@index([orderId, tableId]) // ⚡ PERFORMANCE: Joint lookup
  @@index([restaurantId]) // ⚡ PERFORMANCE: Multi-tenant fetching
  @@index([restaurantId, status]) // ⚡ PERFORMANCE: Multi-tenant fetching
}

model Customer {
  id                String             @id @default(dbgenerated("(gen_random_uuid())::text"))
  phone             String             @unique
  name              String?
  totalVisits       Int                @default(0)
  totalSpend        Float              @default(0)
  pointsBalance     Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @default(now()) @updatedAt
  bills             Bill[]
  pointTransactions PointTransaction[]

  @@index([phone])
}

model PointTransaction {
  id         String               @id @default(dbgenerated("(gen_random_uuid())::text"))
  customerId String
  billId     String?
  points     Int
  type       PointTransactionType
  createdAt  DateTime             @default(now())
  bill       Bill?                @relation(fields: [billId], references: [id])
  customer   Customer             @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([billId])
}

model User {
  id                  String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  email               String      @unique
  password            String
  name                String
  image               String?
  role                Role        @default(STAFF)
  active              Boolean     @default(true)
  restaurantId        String?
  createdAt           DateTime    @default(now())
  cancelledOrderItems OrderItem[]
  restaurant          Restaurant? @relation(fields: [restaurantId], references: [id])
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RUNNING    // Food served, customers eating, might order more
  RESERVED
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  SERVED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
}

enum BillStatus {
  PENDING
  PAID
  CANCELLED
}

enum Role {
  ADMIN
  MANAGER
  WAITER
  CHEF
  STAFF
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  PARCEL
  DELIVERY
}

enum DietType {
  VEG
  NON_VEG
}

enum PortionType {
  HALF
  FULL
}

enum PointTransactionType {
  EARNED
  REDEEMED
}

enum ItemStatus {
  ACTIVE
  CANCELLED
}
